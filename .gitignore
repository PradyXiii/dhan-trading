# Secret credentials - never upload these
.env

# Python cache files - not needed in version control
__pycache__/
*.pyc
*.pyo

# CatBoost training artifacts (auto-created when model trains)
catboost_info/

# Data files generated during backtest / live trading
# SECURITY: These files contain trade history, P&L, credentials — never commit
*.csv
*.json
*.pkl
data/
data/live_trades.csv
data/live_spread_trades.csv
data/paper_trades.csv
data/paper_performance.csv
data/midday_checkpoints.csv
data/news_sentiment.json
data/today_trade.json
data/vix_threshold.json
data/intraday_options_cache/
data/exit_completed_*.marker
models/
models/*.pkl
models/*.json
models/ensemble/
backtest_results/
*.backtest
*.bak

# Claude Code project config — negation MUST come after the *.json rule above
# These .claude/ files are safe to commit (no credentials, no P&L data)
!.claude/settings.json
!.claude/commands/
!.claude/commands/*.md
!.claude/hooks/
!.claude/hooks/*.sh

# Local-only scripts (VM only, never published)
portfolio.py
portfolio_tracker.py
refresh_token.py
test_order.py
validate_token_renewal.py
scripts/
logs/
models/

# GAS morning brief scripts — never committed (contain private prompts/logic)
*.gs
